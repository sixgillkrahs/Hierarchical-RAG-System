NODE_ENV=development
PORT=3000
APP_NAME=Hierarchical RAG API
FRONTEND_ORIGIN=http://localhost:5173
DB_TYPE=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=hierarchical_rag
DB_SYNCHRONIZE=false
DB_LOGGING=false
DB_RUN_MIGRATIONS=true
DB_SSL=false
JWT_SECRET=change-this-in-development
JWT_EXPIRES_IN=1d
AUTH_COOKIE_NAME=access_token
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=lax
AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_MAX_AGE_MS=86400000
ADMIN_EMAIL=admin@gmail.com
ADMIN_PASSWORD=123456aA@
ADMIN_DISPLAY_NAME=System Administrator
PYTHON_API_BASE_URL=http://127.0.0.1:8000
PYTHON_API_TIMEOUT_MS=10000
STORAGE_CACHE_TTL_MS=30000
RAG_DEFAULT_TOP_K=5
VECTOR_STORE_PROVIDER=memory
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
CHAT_MODEL=gpt-4o-mini
